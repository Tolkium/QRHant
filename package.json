{
  "name": "qrhunt",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:lan": "ng serve --host 0.0.0.0",
    "start:supabase": "ng serve --configuration=supabase",
    "start:supabase:lan": "ng serve --configuration=supabase --host 0.0.0.0",
    "build": "ng build",
    "build:pages": "node scripts/write-env.mjs && ng build --configuration=pages",
    "build:supabase": "ng build --configuration=supabase",
    "supabase:link:dev": "supabase link --project-ref rvtltgrlsmapwonmwsbf",
    "supabase:link:prod": "supabase link --project-ref wsafofmssdycacqjzclv",
    "supabase:push": "supabase db push",
    "supabase:push:dev": "supabase link --project-ref rvtltgrlsmapwonmwsbf && supabase db push",
    "supabase:push:prod": "supabase link --project-ref wsafofmssdycacqjzclv && supabase db push",
    "supabase:functions": "supabase functions deploy sync-finds && supabase functions deploy generate-codes && supabase functions deploy admin-reset-password",
    "supabase:functions:dev": "supabase link --project-ref rvtltgrlsmapwonmwsbf && npm run supabase:functions",
    "supabase:functions:prod": "supabase link --project-ref wsafofmssdycacqjzclv && npm run supabase:functions",
    "seed:supabase": "node scripts/seed-supabase.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "android:sync": "ng build && cap sync android",
    "android:open": "cap open android"
  },
  "private": true,
  "packageManager": "npm@11.14.1",
  "dependencies": {
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@jsverse/transloco": "^8.4.0",
    "@sentry/angular": "^10.63.0",
    "@supabase/supabase-js": "^2.110.0",
    "canvas-confetti": "^1.9.4",
    "hash-wasm": "^4.12.0",
    "qrcode": "^1.5.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zxing-wasm": "^3.1.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/qrcode": "^1.5.6",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.16",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
